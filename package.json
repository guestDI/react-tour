{
  "name": "react-product-tour-guide",
  "version": "0.1.0",
  "type": "module",
  "description": "A flexible and accessible product tour component for React applications",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "style": "dist/index.css",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-styles.mjs",
    "build": "tsup",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.6.1",
    "@floating-ui/react": "^0.26.4",
    "clsx": "^2.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.14",
    "@storybook/addon-onboarding": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/builder-vite": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@storybook/test": "^8.6.14",
    "@storybook/testing-library": "^0.2.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.5",
    "storybook": "^8.6.14",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.0.2",
    "typescript": "~5.3.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^5.1.3",
    "vitest": "^1.2.2"
  },
  "keywords": [
    "react",
    "tour",
    "guide",
    "onboarding",
    "product-tour",
    "walkthrough",
    "tutorial",
    "accessibility",
    "a11y",
    "ui",
    "components",
    "typescript",
    "floating-ui",
    "tailwindcss"
  ],
  "author": {
    "name": "Dzmitry Ihnatovich",
    "email": "ignatovich.dm@gmail.com",
    "url": "https://github.com/guestDI"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/guestDI/react-tour-guide.git"
  },
  "bugs": {
    "url": "https://github.com/guestDI/react-tour-guide/issues"
  },
  "homepage": "https://github.com/guestDI/react-tour-guide#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": ["./src/styles/inject.ts", "./dist/index.js", "./dist/index.mjs"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  }
}
